    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "@aws-sdk/client-s3": "^3.540.0",
    "@aws-sdk/s3-request-presigner": "^3.540.0",
    "nodemailer": "^6.9.13",
    "axios": "^1.6.8",
    "zod": "^3.22.4",
    "morgan": "^1.10.0",
    "cookie-parser": "^1.4.6",
    "prisma": "^5.10.0"
