{
  "name": "jekafly-api",
  "version": "1.0.0",
  "description": "Jekafly Visa Platform — Production API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "postinstall": "node node_modules/prisma/build/index.js generate",
