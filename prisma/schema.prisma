generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ───────────────────────────────────────────────────────────────────
model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  phone        String?
  passwordHash String
  role         Role          @default(USER)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  applications Application[]
  documents    Document[]
  payments     Payment[]
  policies     InsurancePolicy[]
  refreshTokens RefreshToken[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

// ─── Refresh Tokens ──────────────────────────────────────────────────────────
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ─── Applications ─────────────────────────────────────────────────────────────
model Application {
  id              String            @id @default(uuid())
  ref             String            @unique
  userId          String
  user            User              @relation(fields: [userId], references: [id])

  // Trip details
  destination     String
  purpose         String
  visaType        String?
  travelDate      DateTime?
  returnDate      DateTime?

  // Applicant details
  applicantName   String
  email           String
  phone           String?
  nationality     String?
  passportNumber  String?
  passportExpiry  DateTime?
  dob             DateTime?

  // Status & payment
  status          ApplicationStatus @default(RECEIVED)
  paid            Boolean           @default(false)
  fee             Int               @default(0)  // in kobo

  // JSON fields
  feeBreakdown    Json?
  travellers      Json?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  statusHistory   StatusHistory[]
  documents       Document[]
  payments        Payment[]

  @@map("applications")
}

enum ApplicationStatus {
  RECEIVED
  PROCESSING
  EMBASSY
  APPROVED
  DELIVERED
  REJECTED
}

model StatusHistory {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  status        ApplicationStatus
  note          String
  createdAt     DateTime    @default(now())

  @@map("status_history")
}

// ─── Documents ───────────────────────────────────────────────────────────────
model Document {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  applicationId String?
  application   Application? @relation(fields: [applicationId], references: [id])

  name          String
  key           String      // S3 object key
  mimeType      String
  size          Int         // bytes
  docIndex      Int?        // position in visa requirements doc list

  uploadedAt    DateTime    @default(now())

  @@map("documents")
}

// ─── Payments ────────────────────────────────────────────────────────────────
model Payment {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  applicationId String?
  application   Application?  @relation(fields: [applicationId], references: [id])

  reference     String        @unique  // Paystack reference
  type          PaymentType
  amount        Int           // kobo
  status        PaymentStatus @default(INITIATED)
  metadata      Json?

  initiatedAt   DateTime      @default(now())
  paidAt        DateTime?

  @@map("payments")
}

enum PaymentType {
  VISA
  INSURANCE
  CONSULTATION
}

enum PaymentStatus {
  INITIATED
  SUCCESS
  FAILED
}

// ─── Insurance ───────────────────────────────────────────────────────────────
model InsurancePolicy {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  paymentRef  String   @unique

  plan        String
  destination String?
  travelDate  DateTime?
  travellers  Int      @default(1)
  amount      Int      // kobo
  status      String   @default("active")

  purchasedAt DateTime @default(now())

  @@map("insurance_policies")
}

// ─── Fees ────────────────────────────────────────────────────────────────────
model Fee {
  id          String   @id @default(uuid())
  country     String   @unique
  amount      Int      // naira
  isDefault   Boolean  @default(false)
  enabled     Boolean  @default(true)
  updatedAt   DateTime @updatedAt

  @@map("fees")
}

model ServiceFee {
  id        String   @id @default("singleton")
  amount    Int      @default(25000)  // naira
  updatedAt DateTime @updatedAt

  @@map("service_fee")
}

// ─── Visa Requirements ───────────────────────────────────────────────────────
model VisaRequirement {
  id          String   @id @default(uuid())
  country     String   @unique
  flag        String?
  region      String?
  visaType    String?
  fee         String?  // display string e.g. "€80"
  processing  String?  // display string e.g. "10-15 business days"
  docs        Json?    // string[]
  updatedAt   DateTime @updatedAt

  @@map("visa_requirements")
}
